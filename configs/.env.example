# gmmff signaling server configuration
# Copy to .env and fill in your values.
# Never commit a filled-in .env file to version control.

# ── Network ───────────────────────────────────────────────────────────────────

# TCP address the server listens on.
# In production behind a reverse proxy, keep this as :8080 (or any internal port).
GMMFF_ADDR=:8080

# ── Redis ─────────────────────────────────────────────────────────────────────

# Redis connection URL.
# Formats:
#   redis://[user:password@]host[:port][/db]          (plain)
#   rediss://[user:password@]host[:port][/db]         (TLS)
#   redis+sentinel://master@sentinel1:port,sentinel2  (Sentinel)
GMMFF_REDIS_URL=redis://localhost:6379/0

# ── Logging ───────────────────────────────────────────────────────────────────

# Log level: trace | debug | info | warn | error
# Use "info" in production.  "debug" in staging.  Never "trace" in production
# (even though trace logs contain no user data, they are very verbose).
GMMFF_LOG_LEVEL=info

# ── TLS (optional) ────────────────────────────────────────────────────────────
# Recommended: terminate TLS at a reverse proxy (Caddy, nginx, AWS ALB).
# Use these only if you want the server to terminate TLS directly.

# GMMFF_TLS_CERT=/etc/gmmff/tls.crt
# GMMFF_TLS_KEY=/etc/gmmff/tls.key
