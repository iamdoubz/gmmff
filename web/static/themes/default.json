  "font_weight_normal": "400",
  "font_weight_medium": "500",
  "font_weight_bold":   "600",
  "line_height":        "1.5",

  "radius_sm":   "6px",
  "radius_md":   "10px",
  "radius_lg":   "16px",
  "radius_pill": "9999px",

  "spacing_xs": "4px",
